{
  "name": "@remotectrl/api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "start": "node dist/index.mjs",
    "start:3000": "node -e \"process.env.PORT=3000;import('./dist/index.mjs')\"",
    "start:tray": "tsx src/tray.ts",
    "bundle:exe": "npx @yao-pkg/pkg dist/tray.mjs --targets node20-win-x64 --out-path release/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "expo-server-sdk": "^6.1.0",
    "node-windows": "1.0.0-beta.8",
    "open": "^11.0.0",
    "systray2": "^2.1.4",
    "express": "^5.0.0",
    "express-rate-limit": "^7.5.1",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^11.0.0",
    "ssh2": "^1.16.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.24.0",
    "@yao-pkg/pkg": "^5.12.0",
    "esbuild-plugin-pino": "^2.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "yao-pkg": {
    "scripts": "dist/tray.mjs",
    "assets": [
      "dist/index.mjs",
      "data/**",
      "node_modules/ssh2/**",
      "node_modules/ws/**"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "release/"
  }
}