{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "ci": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "http://localhost:3000"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "simulator": false,
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "https://register-undergraduate-requirement-matter.trycloudflare.com"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "https://register-undergraduate-requirement-matter.trycloudflare.com"
      }
    }
  },
  "submit": {
    "production": {},
    "preview": {
      "ios": {
        "ascAppId": "6785305125",
        "ascApiKeyPath": "$EXPO_ASC_API_KEY_PATH",
        "ascApiKeyId": "$EXPO_ASC_API_KEY_ID",
        "ascApiKeyIssuerId": "$EXPO_ASC_API_KEY_ISSUER_ID"
      }
    }
  }
}
