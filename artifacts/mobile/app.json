{
  "expo": {
    "name": "RemoteCTRL",
    "slug": "remotectrl",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "remotectrl",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.remotectrl.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "RemoteCTRL uses Face ID to lock the app and protect your server credentials."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-android-foreground.png",
        "backgroundColor": "#0d0d0d"
      },
      "package": "com.remotectrl.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-local-authentication",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
