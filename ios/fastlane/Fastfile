default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build the RemoteCliControl app and upload it to TestFlight"
  lane :beta do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(type: "appstore", readonly: true)

    xcodeproj_path = Dir.glob("*.xcodeproj").first
    scheme_name = ENV["IOS_SCHEME"] || "RemoteCTRL"

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: xcodeproj_path
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: xcodeproj_path,
      team_id: ENV["sigh_com.remotectrl.app_appstore_team-id"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.remotectrl.app",
      profile_name: ENV["sigh_com.remotectrl.app_appstore_profile-name"]
    )

    build_app(
      workspace: Dir.glob("*.xcworkspace").first,
      scheme: scheme_name,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.remotectrl.app" => ENV["sigh_com.remotectrl.app_appstore_profile-name"]
        }
      }
    )

    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "One-time bootstrap: fetch or create the distribution cert + provisioning profile (run locally, not in CI)"
  lane :bootstrap_certs do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(type: "appstore", readonly: false)
  end

  desc "List distribution certificates on the account, with id/serial/name/expiry (read-only, safe)"
  lane :list_certs do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    certs = Spaceship::ConnectAPI::Certificate.all
    certs.each do |c|
      UI.message("id=#{c.id} serial=#{c.serial_number} name=#{c.name} type=#{c.certificate_type} expires=#{c.expiration_date}")
    end
  end

  desc "Revoke one certificate by its ASC resource id (pass CERT_ID env var). Irreversible."
  lane :revoke_cert do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    cert_id = ENV["CERT_ID"]
    UI.user_error!("Set CERT_ID to the certificate's ASC resource id") unless cert_id

    target = Spaceship::ConnectAPI::Certificate.all.find { |c| c.id == cert_id }
    UI.user_error!("No certificate found with id=#{cert_id}") unless target

    UI.message("Revoking id=#{target.id} serial=#{target.serial_number} name=#{target.name}")
    target.delete!
    UI.success("Revoked certificate id=#{target.id}")
  end
end
