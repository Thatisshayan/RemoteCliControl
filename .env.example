PORT=3000
# Required — generate a strong random value, e.g.: openssl rand -hex 32
# The server refuses to start with CLOUDFLARE_TUNNEL enabled if this is unset.
API_TOKEN=

# Set to "true" to auto-start Cloudflare Tunnel when the server starts.
# Requires cloudflared.exe in the repo root (download from https://github.com/cloudflare/cloudflared/releases).
CLOUDFLARE_TUNNEL=true

# Optional: override where the tunnel URL is written (default: ./data/tunnel-url.txt)
# TUNNEL_URL_PATH=./data/tunnel-url.txt
